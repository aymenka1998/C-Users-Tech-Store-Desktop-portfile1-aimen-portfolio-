{
  "compilerOptions": {
    "target": "ESNext", // تم التحديث لدعم أحدث ميزات JS
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false, // يفضل جعله false مؤقتاً لضمان نجاح الـ Build وتجاوز تعارض الأنواع في Strapi
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"] // تعديل مهم: إذا كانت مجلداتك (app, lib) في المجلد الرئيسي وليس داخل src
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "**/*.js",
    "**/*.jsx",
    "next.config.js",
    "next.config.mjs"
  ],
  "exclude": ["node_modules"]
}
